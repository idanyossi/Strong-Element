# All four of these are required — the server refuses to start without them.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password-here
JWT_SECRET=your-random-secret-here
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

PORT=3001

# Optional. Only set this if a separate trusted origin needs to call the API
# cross-origin (e.g. a staging frontend on a different domain). Leave unset in
# normal operation — the app only ever calls this API same-origin.
# CORS_ORIGIN=https://yourdomain.com
